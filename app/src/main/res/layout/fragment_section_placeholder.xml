<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/space_32">

    <ImageView
        android:id="@+id/section_icon"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/bg_placeholder_icon"
        android:contentDescription="@null"
        android:padding="28dp"
        app:tint="@color/fh_primary" />

    <TextView
        android:id="@+id/section_title"
        style="@style/TextAppearance.FamilyHub.Heading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_24"
        android:gravity="center"
        android:textColor="@color/fh_on_surface" />

    <TextView
        android:id="@+id/section_description"
        style="@style/TextAppearance.FamilyHub.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:gravity="center"
        android:textAlignment="center"
        android:textColor="@color/fh_on_surface_variant" />

    <TextView
        style="@style/TextAppearance.FamilyHub.Overline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_24"
        android:text="@string/in_development"
        android:textColor="@color/fh_primary" />
</LinearLayout>
