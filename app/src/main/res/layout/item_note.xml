<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.FamilyHub.Card.Data"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/card_spacing">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/note_icon"
                android:layout_width="@dimen/icon_tile_size"
                android:layout_height="@dimen/icon_tile_size"
                android:background="@drawable/bg_placeholder_icon"
                android:contentDescription="@null"
                android:padding="@dimen/space_10"
                android:src="@drawable/ic_note" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/note_title"
                    style="@style/TextAppearance.FamilyHub.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2" />

                <TextView
                    android:id="@+id/note_updated"
                    style="@style/TextAppearance.FamilyHub.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4" />
            </LinearLayout>

            <TextView
                android:id="@+id/note_pinned"
                style="@style/TextAppearance.FamilyHub.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill"
                android:paddingStart="@dimen/space_10"
                android:paddingTop="@dimen/space_6"
                android:paddingEnd="@dimen/space_10"
                android:paddingBottom="@dimen/space_6"
                android:text="@string/notes_pinned"
                android:textColor="@color/fh_warning"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/note_content"
            style="@style/TextAppearance.FamilyHub.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:ellipsize="end"
            android:maxLines="4" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/note_category"
                style="@style/TextAppearance.FamilyHub.Caption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/note_type"
                style="@style/TextAppearance.FamilyHub.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/border_width"
            android:layout_marginTop="@dimen/space_12"
            android:background="@color/fh_divider" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pin_note_button"
                    style="@style/Widget.FamilyHub.Button.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="@string/notes_pin"
                    android:textColor="@color/fh_warning" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/archive_note_button"
                    style="@style/Widget.FamilyHub.Button.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="@string/notes_archive"
                    android:textColor="@color/fh_module_documents" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/edit_note_button"
                    style="@style/Widget.FamilyHub.Button.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="@string/edit"
                    android:textColor="@color/fh_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/delete_note_button"
                    style="@style/Widget.FamilyHub.Button.Danger"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target_min"
                    android:text="@string/remove"
                    android:textColor="@color/fh_error" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
