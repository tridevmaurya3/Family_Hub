<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_20">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FamilyHub.Card.Flat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/fh_module_finance_container"
            app:strokeColor="@color/fh_module_finance">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="@dimen/icon_tile_size"
                    android:layout_height="@dimen/icon_tile_size"
                    android:background="@drawable/bg_placeholder_icon"
                    android:contentDescription="@null"
                    android:padding="@dimen/space_10"
                    android:src="@drawable/ic_wallet"
                    app:tint="@color/fh_module_finance" />

                <TextView
                    android:id="@+id/finance_editor_title"
                    style="@style/TextAppearance.FamilyHub.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_12"
                    android:layout_weight="1"
                    android:textColor="@color/fh_on_success_container" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/TextAppearance.FamilyHub.Overline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:text="@string/finance_type"
            android:textColor="@color/fh_module_finance" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FamilyHub.Card.Subtle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_6">

            <RadioGroup
                android:id="@+id/finance_type_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_10"
                android:paddingEnd="@dimen/space_10">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/type_expense_button"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="@string/finance_expense"
                    android:textColor="@color/fh_on_surface" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/type_income_button"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_weight="1"
                    android:text="@string/finance_income"
                    android:textColor="@color/fh_on_surface" />

            </RadioGroup>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/finance_amount_layout"
            style="@style/Widget.FamilyHub.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/form_field_spacing"
            android:hint="@string/finance_amount"
            app:prefixText="₹ ">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/finance_amount_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/finance_category_layout"
            style="@style/Widget.FamilyHub.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/form_field_spacing"
            android:hint="@string/finance_category">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/finance_category_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/finance_entry_date_layout"
            style="@style/Widget.FamilyHub.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/form_field_spacing"
            android:hint="@string/finance_entry_date"
            app:endIconDrawable="@drawable/ic_reminder"
            app:endIconMode="custom"
            app:endIconTint="@color/fh_module_finance">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/finance_entry_date_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:inputType="none"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/finance_note_layout"
            style="@style/Widget.FamilyHub.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/form_field_spacing"
            android:hint="@string/finance_note">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/finance_note_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="4"
                android:minLines="3" />

        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_finance_button"
                style="@style/Widget.FamilyHub.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginEnd="@dimen/space_4"
                android:layout_weight="1"
                android:text="@string/cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_finance_button"
                style="@style/Widget.FamilyHub.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="@dimen/space_4"
                android:layout_weight="1"
                android:text="@string/save_finance_entry" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
