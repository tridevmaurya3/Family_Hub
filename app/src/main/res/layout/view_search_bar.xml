<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.FamilyHub.Card.Flat"
    android:layout_width="match_parent"
    android:layout_height="@dimen/input_min_height"
    app:cardCornerRadius="@dimen/radius_14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_16"
        android:paddingEnd="@dimen/space_8">

        <ImageView
            android:id="@+id/imgSearch"
            android:layout_width="@dimen/icon_size_medium"
            android:layout_height="@dimen/icon_size_medium"
            android:contentDescription="@null"
            android:src="@drawable/ic_search"
            app:tint="@color/fh_primary" />

        <EditText
            android:id="@+id/edtSearch"
            style="@style/TextAppearance.FamilyHub.Body"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/space_12"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="@string/search_hint_dashboard"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/fh_text_primary"
            android:textColorHint="@color/fh_text_secondary" />

        <ImageButton
            android:id="@+id/btnVoice"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:padding="@dimen/space_12"
            android:src="@drawable/ic_mic"
            android:visibility="gone"
            app:tint="@color/fh_primary" />

        <ImageButton
            android:id="@+id/btnFilter"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:padding="@dimen/space_12"
            android:src="@drawable/ic_filter"
            android:visibility="gone"
            app:tint="@color/fh_primary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
