<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_20">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FamilyHub.Card.Flat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/fh_module_reminders_container"
            app:strokeColor="@color/fh_module_reminders">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="@dimen/icon_tile_size"
                    android:layout_height="@dimen/icon_tile_size"
                    android:background="@drawable/bg_placeholder_icon"
                    android:contentDescription="@null"
                    android:padding="@dimen/space_10"
                    android:src="@drawable/ic_reminder"
                    app:tint="@color/fh_module_reminders" />

                <TextView
                    android:id="@+id/reminder_editor_title"
                    style="@style/TextAppearance.FamilyHub.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_12"
                    android:layout_weight="1"
                    android:textColor="@color/fh_on_warning_container" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/reminder_title_layout"
            style="@style/Widget.FamilyHub.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:hint="@string/reminder_title">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/reminder_title_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/reminder_date_layout"
            style="@style/Widget.FamilyHub.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/form_field_spacing"
            android:hint="@string/reminder_date"
            app:endIconDrawable="@drawable/ic_reminder"
            app:endIconMode="custom"
            app:endIconTint="@color/fh_module_reminders">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/reminder_date_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:inputType="none"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/reminder_time_layout"
            style="@style/Widget.FamilyHub.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/form_field_spacing"
            android:hint="@string/reminder_time"
            app:endIconDrawable="@drawable/ic_reminder"
            app:endIconMode="custom"
            app:endIconTint="@color/fh_module_reminders">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/reminder_time_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:inputType="none"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/TextAppearance.FamilyHub.Overline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:text="@string/reminder_repeat"
            android:textColor="@color/fh_module_reminders" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FamilyHub.Card.Subtle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_6">

            <RadioGroup
                android:id="@+id/reminder_repeat_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_10"
                android:paddingEnd="@dimen/space_10">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/repeat_once_button"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="@string/reminder_once"
                    android:textColor="@color/fh_on_surface" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/repeat_daily_button"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_weight="1"
                    android:text="@string/reminder_daily"
                    android:textColor="@color/fh_on_surface" />

            </RadioGroup>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FamilyHub.Card.Subtle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/form_field_spacing">

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/reminder_enabled_switch"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_min_height"
                android:checked="true"
                android:paddingStart="@dimen/space_12"
                android:paddingEnd="@dimen/space_12"
                android:text="@string/reminder_enabled"
                android:textColor="@color/fh_on_surface" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/reminder_note_layout"
            style="@style/Widget.FamilyHub.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/form_field_spacing"
            android:hint="@string/reminder_note">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/reminder_note_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="4"
                android:minLines="3" />

        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_reminder_button"
                style="@style/Widget.FamilyHub.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginEnd="@dimen/space_4"
                android:layout_weight="1"
                android:text="@string/cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_reminder_button"
                style="@style/Widget.FamilyHub.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="@dimen/space_4"
                android:layout_weight="1"
                android:text="@string/save_reminder" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
