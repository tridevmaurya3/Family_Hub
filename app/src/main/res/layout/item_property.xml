<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.FamilyHub.Card.Flat"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/card_spacing"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/icon_tile_size"
                android:layout_height="@dimen/icon_tile_size"
                android:background="@drawable/bg_placeholder_icon"
                android:contentDescription="@null"
                android:padding="@dimen/space_10"
                android:src="@drawable/ic_property"
                app:tint="@color/fh_module_property" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/property_title"
                    style="@style/TextAppearance.FamilyHub.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/property_owner"
                    style="@style/TextAppearance.FamilyHub.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_8"
                app:cardBackgroundColor="@color/fh_module_property_container"
                app:cardCornerRadius="@dimen/radius_14"
                app:cardElevation="0dp"
                app:strokeColor="@color/fh_module_property"
                app:strokeWidth="@dimen/border_width">

                <TextView
                    android:id="@+id/property_type"
                    style="@style/TextAppearance.FamilyHub.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/space_10"
                    android:paddingTop="@dimen/space_6"
                    android:paddingEnd="@dimen/space_10"
                    android:paddingBottom="@dimen/space_6"
                    android:textColor="@color/fh_module_property"
                    android:textStyle="bold" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <TextView
            android:id="@+id/property_location"
            style="@style/TextAppearance.FamilyHub.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/property_area"
                style="@style/TextAppearance.FamilyHub.Caption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/property_value"
                style="@style/TextAppearance.FamilyHub.CardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/fh_module_property" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/border_width"
            android:layout_marginTop="@dimen/space_12"
            android:background="@color/fh_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/edit_property_button"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target_min"
                android:minWidth="0dp"
                android:text="@string/edit"
                android:textColor="@color/fh_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/delete_property_button"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target_min"
                android:layout_marginStart="@dimen/space_4"
                android:minWidth="0dp"
                android:text="@string/remove"
                android:textColor="@color/fh_error" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
