<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fh_background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/space_24"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingBottom="@dimen/space_32">

        <!-- Dashboard header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.FamilyHub.Heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_greeting"
                    android:textColor="@color/fh_on_surface" />

                <TextView
                    style="@style/TextAppearance.FamilyHub.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:text="@string/dashboard_intro"
                    android:textColor="@color/fh_on_surface_variant" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/notification_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/content_description_notifications"
                android:padding="12dp"
                android:src="@drawable/ic_bell"
                app:tint="@color/fh_on_surface" />

        </LinearLayout>

        <!-- Reusable dashboard search -->
        <com.tridev.familyhub.core.ui.search.SearchBarView
            android:id="@+id/dashboard_search_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20" />

        <!-- Reusable Family Hub Hero Card -->
        <com.tridev.familyhub.core.ui.cards.HeroCardView
            android:id="@+id/dashboard_hero_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16" />

        <!-- Quick actions heading -->
        <TextView
            style="@style/TextAppearance.FamilyHub.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:text="@string/quick_actions"
            android:textColor="@color/fh_on_surface" />

        <!-- Quick actions first row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/quick_family"
                style="@style/Widget.FamilyHub.Card.Flat"
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/fh_module_family_container"
                app:strokeColor="@color/fh_module_family">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/family_members"
                        android:src="@drawable/ic_family"
                        app:tint="@color/fh_primary" />

                    <TextView
                        style="@style/TextAppearance.FamilyHub.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:gravity="center"
                        android:text="@string/family_members"
                        android:textColor="@color/fh_on_surface" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="@dimen/space_12"
                android:layout_height="0dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/quick_reminder"
                style="@style/Widget.FamilyHub.Card.Flat"
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/fh_module_reminders_container"
                app:strokeColor="@color/fh_module_reminders">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/add_reminder"
                        android:src="@drawable/ic_reminder"
                        app:tint="@color/fh_tertiary" />

                    <TextView
                        style="@style/TextAppearance.FamilyHub.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:gravity="center"
                        android:text="@string/add_reminder"
                        android:textColor="@color/fh_on_surface" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Quick actions second row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/quick_expense"
                style="@style/Widget.FamilyHub.Card.Flat"
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/fh_module_finance_container"
                app:strokeColor="@color/fh_module_finance">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/add_expense"
                        android:src="@drawable/ic_wallet"
                        app:tint="@color/fh_success" />

                    <TextView
                        style="@style/TextAppearance.FamilyHub.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:gravity="center"
                        android:text="@string/add_expense"
                        android:textColor="@color/fh_on_surface" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="@dimen/space_12"
                android:layout_height="0dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/quick_family_live"
                style="@style/Widget.FamilyHub.Card.Flat"
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/fh_module_family_container"
                app:strokeColor="@color/fh_module_family">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/family_live"
                        android:src="@drawable/ic_family"
                        app:tint="@color/fh_primary" />

                    <TextView
                        style="@style/TextAppearance.FamilyHub.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:gravity="center"
                        android:text="@string/family_live"
                        android:textColor="@color/fh_primary_dark" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Overview heading -->
        <TextView
            style="@style/TextAppearance.FamilyHub.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_32"
            android:text="@string/dashboard_overview"
            android:textColor="@color/fh_on_surface" />

        <!-- Reusable overview status cards -->
        <com.tridev.familyhub.core.ui.cards.StatusCardView
            android:id="@+id/card_finance_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12" />

        <com.tridev.familyhub.core.ui.cards.StatusCardView
            android:id="@+id/card_health_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8" />

        <com.tridev.familyhub.core.ui.cards.StatusCardView
            android:id="@+id/card_family_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8" />

        <com.tridev.familyhub.core.ui.cards.StatusCardView
            android:id="@+id/card_document_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8" />

        <!-- Today overview heading -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_32"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextAppearance.FamilyHub.SectionTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/today_overview"
                android:textColor="@color/fh_on_surface" />

            <TextView
                style="@style/TextAppearance.FamilyHub.Overline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/view_all"
                android:textColor="@color/fh_primary" />

        </LinearLayout>

        <!-- Upcoming reminder card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FamilyHub.Card.Flat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            app:cardBackgroundColor="@color/fh_module_reminders_container"
            app:strokeColor="@color/fh_module_reminders">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_16">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_placeholder_icon"
                    android:contentDescription="@string/upcoming_reminder"
                    android:padding="9dp"
                    android:src="@drawable/ic_reminder"
                    app:tint="@color/fh_tertiary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_12"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/dashboard_upcoming_reminder_title"
                        style="@style/TextAppearance.FamilyHub.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/upcoming_reminder"
                        android:textColor="@color/fh_on_surface" />

                    <TextView
                        android:id="@+id/dashboard_upcoming_reminder_detail"
                        style="@style/TextAppearance.FamilyHub.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/upcoming_reminder_detail"
                        android:textColor="@color/fh_on_surface_variant" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Finance summary card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FamilyHub.Card.Flat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            app:cardBackgroundColor="@color/fh_module_finance_container"
            app:strokeColor="@color/fh_module_finance">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_16">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_placeholder_icon"
                    android:contentDescription="@string/monthly_spend"
                    android:padding="9dp"
                    android:src="@drawable/ic_wallet"
                    app:tint="@color/fh_success" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_12"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.FamilyHub.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monthly_spend"
                        android:textColor="@color/fh_on_surface" />

                    <TextView
                        android:id="@+id/dashboard_monthly_expense_detail"
                        style="@style/TextAppearance.FamilyHub.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/monthly_spend_detail"
                        android:textColor="@color/fh_on_surface_variant" />

                </LinearLayout>

                <TextView
                    android:id="@+id/dashboard_monthly_expense_value"
                    style="@style/TextAppearance.FamilyHub.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/monthly_spend_value"
                    android:textColor="@color/fh_success" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
