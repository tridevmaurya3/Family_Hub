<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fh_background"
    android:paddingStart="@dimen/screen_padding_horizontal"
    android:paddingTop="@dimen/space_24"
    android:paddingEnd="@dimen/screen_padding_horizontal">

    <TextView
        android:id="@+id/property_screen_title"
        style="@style/TextAppearance.FamilyHub.Heading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/property_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/property_subtitle"
        style="@style/TextAppearance.FamilyHub.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="@string/property_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/property_screen_title" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/property_search_layout"
        style="@style/Widget.FamilyHub.TextInputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_20"
        android:hint="@string/property_search_hint"
        app:endIconMode="clear_text"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/fh_module_property"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/property_subtitle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/property_search_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/property_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="@dimen/space_16"
        android:paddingBottom="104dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/property_search_layout" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/property_empty_state"
        style="@style/Widget.FamilyHub.Card.Flat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_24"
        android:visibility="gone"
        app:cardBackgroundColor="@color/fh_module_property_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/property_search_layout"
        app:strokeColor="@color/fh_module_property">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_32">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_placeholder_icon"
                android:contentDescription="@null"
                android:padding="@dimen/space_20"
                android:src="@drawable/ic_property"
                app:tint="@color/fh_module_property" />

            <TextView
                style="@style/TextAppearance.FamilyHub.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:text="@string/property_empty_title" />

            <TextView
                style="@style/TextAppearance.FamilyHub.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:gravity="center"
                android:text="@string/property_empty_detail"
                android:textAlignment="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/empty_add_property_button"
                style="@style/Widget.FamilyHub.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/space_20"
                android:text="@string/property_add"
                app:icon="@drawable/ic_add"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/space_6" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
