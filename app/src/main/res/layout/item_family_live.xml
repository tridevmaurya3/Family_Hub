<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="10dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/fh_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/fh_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_placeholder_icon"
                    android:gravity="center"
                    android:text="TM"
                    android:textColor="@color/fh_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/viewStatusDot"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_gravity="end|bottom"
                    android:background="@drawable/bg_family_live_status_dot" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMemberName"
                    style="@style/TextAppearance.FamilyHub.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:text="Tridev Maurya"
                    android:textColor="@color/fh_on_surface"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvLocation"
                    style="@style/TextAppearance.FamilyHub.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:maxLines="1"
                    android:text="Home"
                    android:textColor="@color/fh_on_surface_variant"
                    android:ellipsize="end" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="Online"
                android:textColor="@color/fh_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="12dp"
            android:background="@color/fh_outline" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvMovement"
                style="@style/TextAppearance.FamilyHub.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="At home"
                android:textColor="@color/fh_on_surface" />

            <TextView
                android:id="@+id/tvBattery"
                style="@style/TextAppearance.FamilyHub.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Battery 87%"
                android:textColor="@color/fh_on_surface" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvConnection"
            style="@style/TextAppearance.FamilyHub.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:text="Internet available"
            android:textColor="@color/fh_on_surface_variant" />

        <TextView
            android:id="@+id/tvLastUpdated"
            style="@style/TextAppearance.FamilyHub.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Updated just now"
            android:textColor="@color/fh_on_surface_variant"
            android:textSize="12sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>