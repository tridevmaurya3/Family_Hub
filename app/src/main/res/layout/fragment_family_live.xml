<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fh_background"
    android:paddingStart="@dimen/screen_padding_horizontal"
    android:paddingTop="@dimen/space_24"
    android:paddingEnd="@dimen/screen_padding_horizontal">

    <TextView
        android:id="@+id/tvFamilyLiveTitle"
        style="@style/TextAppearance.FamilyHub.Heading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/family_live"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvFamilyLiveSubtitle"
        style="@style/TextAppearance.FamilyHub.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:text="@string/family_live_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFamilyLiveTitle" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/summaryCard"
        style="@style/Widget.FamilyHub.Card.Flat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_20"
        app:cardBackgroundColor="@color/fh_module_family_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFamilyLiveSubtitle"
        app:strokeColor="@color/fh_module_family">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding">

            <ImageView
                android:layout_width="@dimen/icon_tile_size"
                android:layout_height="@dimen/icon_tile_size"
                android:background="@drawable/bg_placeholder_icon"
                android:contentDescription="@null"
                android:padding="@dimen/space_10"
                android:src="@drawable/ic_family"
                app:tint="@color/fh_module_family" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.FamilyHub.Overline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/family_live_status_title"
                    android:textColor="@color/fh_module_family" />

                <TextView
                    android:id="@+id/tvMemberCount"
                    style="@style/TextAppearance.FamilyHub.SectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:text="@string/family_live_member_count"
                    android:textColor="@color/fh_on_primary_container" />

                <TextView
                    style="@style/TextAppearance.FamilyHub.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:text="@string/family_live_privacy_detail"
                    android:textColor="@color/fh_on_primary_container" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/listHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_24"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/summaryCard">

        <TextView
            style="@style/TextAppearance.FamilyHub.SectionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/family_live_members_title" />

        <TextView
            style="@style/TextAppearance.FamilyHub.Overline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/family_live_list_view"
            android:textColor="@color/fh_module_family" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerFamilyLive"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="@dimen/space_12"
        android:paddingBottom="@dimen/space_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/listHeader" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/family_live_empty_state"
        style="@style/Widget.FamilyHub.Card.Flat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:visibility="gone"
        app:cardBackgroundColor="@color/fh_module_family_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/listHeader"
        app:strokeColor="@color/fh_module_family">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_32">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_placeholder_icon"
                android:contentDescription="@null"
                android:padding="@dimen/space_20"
                android:src="@drawable/ic_family"
                app:tint="@color/fh_module_family" />

            <TextView
                style="@style/TextAppearance.FamilyHub.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:gravity="center"
                android:text="@string/family_live_empty_title" />

            <TextView
                style="@style/TextAppearance.FamilyHub.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:gravity="center"
                android:text="@string/family_live_empty_detail"
                android:textAlignment="center" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
