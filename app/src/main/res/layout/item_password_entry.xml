<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.FamilyHub.Card.Data"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_12"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/icon_tile_size"
                android:layout_height="@dimen/icon_tile_size"
                app:cardBackgroundColor="@color/fh_module_vault_container"
                app:cardCornerRadius="@dimen/radius_14"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/fh_module_vault" />

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/password_entry_title"
                    style="@style/TextAppearance.FamilyHub.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/password_entry_website"
                    style="@style/TextAppearance.FamilyHub.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:ellipsize="end"
                    android:maxLines="1" />

            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/border_width"
            android:layout_marginTop="@dimen/space_12"
            android:background="@color/fh_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/open_password_entry_button"
                style="@style/Widget.FamilyHub.Button.Action"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target_min"
                android:minWidth="0dp"
                android:text="@string/open"
                android:textColor="@color/fh_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/delete_password_entry_button"
                style="@style/Widget.FamilyHub.Button.Danger"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target_min"
                android:layout_marginStart="@dimen/space_4"
                android:minWidth="0dp"
                android:text="@string/remove"
                android:textColor="@color/fh_error" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
