<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".core.FamilyHubApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_family_hub_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_family_hub_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.FamilyHub">

        <activity
            android:name=".feature.main.MainActivity"
            android:exported="false" />

        <activity
            android:name=".feature.main.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FamilyHub.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".core.reminders.ReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".core.reminders.ReminderBootReceiver"
            android:directBootAware="false"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
